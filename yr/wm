	FILE="$HOME/.config/widow/.urlquery"
	
	if [ ! -f $FILE ]; then
	    touch $FILE
	fi
	
	FILEOPT=$(cat $FILE)
	
	OPTIONS="
	[
	${FILEOPT}
	[ \"+\", \"\" ],
	[ \"-\",  \"\" ]
	]
	"
	
	OBJ_LENGTH=$(echo $OPTIONS | jq length)
	OBJ_MENU=$(echo $OPTIONS | jq -r ".[][0]" | dmenu -i -fn 'Terminus:pixelsize=10' -nb black -nf white -sb white -sf black -p "::src")
	OBJ_QRY=$(echo "" | dmenu -i -fn 'Terminus:pixelsize=10' -nb black -nf white -sb white -sf black -p "::query")
	OBJ_KEYWORDS=$(echo "$OBJ_QRY" | tr " " "+")
	OBJ_SELECTED=$(echo "$OBJ_MENU" | cut -d' ' -f1)
	
	main() {
	    for i in $(seq 0 $((OBJ_LENGTH - 1))); do
	        if [ "$OBJ_SELECTED" = "+" ]; then
	            PREFIXMENU=$(echo "" | dmenu -i -fn 'Terminus:pixelsize=10' -nb black -nf white -sb white -sf black -p "::prfx[a]" <&-)
	            URLQUERY=$(echo "" | dmenu -fn 'Terminus:pixelsize=10' -nb black -nf white -sb white -sf black -p "::url[b]" <&-)
	            if [ ! -z "$PREFIXMENU" ]; then
	                echo "[ \"$PREFIXMENU\", \"$URLQUERY\" ]," >> $FILE
	            fi
	
	        elif [ "$OBJ_SELECTED" = "-" ]; then
	            OBJ_MENU=$(echo "$OPTIONS" | jq -r ".[][0]" | head -n -2 | dmenu -fn 'Terminus:pixelsize=10' -nb black -nf white -sb white -sf black -i -p "::del")
	            sed -i "/$OBJ_MENU/d" $FILE
	        fi
	        
	        if [ "$OBJ_SELECTED" = "$(echo "$OPTIONS" | jq -r --arg i "$i" '.[($i|tonumber)][0]')" ]; then
	            URLQUERY=$(echo "$OPTIONS" | jq -r --arg i "$i" '.[($i|tonumber)][1]')
	            KEYWORDS=$(echo "$OBJ_KEYWORDS")
	            xdg-open "${URLQUERY}${KEYWORDS}" 2> /dev/null
